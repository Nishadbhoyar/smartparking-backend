spring.application.name=smartparking
spring.datasource.url=jdbc:mysql://localhost:3306/newsmartdb?createDatabaseIfNotExist=true
spring.datasource.username=root
spring.datasource.password=12345
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.open-in-view=false
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect
spring.jpa.properties.hibernate.jdbc.time_zone=UTC


# ?? JWT Configuration ??????????????????????????????????????????????????????????
# Secret must be at least 32 characters for HS256.
# IMPORTANT: Change this to a long random string in production and keep it secret!
jwt.secret=SmartParkingSecretKey2024ChangeThisInProduction!!
# Token expires after 24 hours (86400000 ms)
jwt.expiration-ms=86400000


smartparking.upload.dir=/var/smartparking/uploads/valet_images/
# FIX: Spring Boot default multipart limit is 1MB. Phone photos are 2-8MB.
# Without this, /api/valet/*/park rejects every image upload with 400.
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=60MB



spring.cache.type=simple



